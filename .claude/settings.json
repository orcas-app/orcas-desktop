{
  "env": {
    "CLAUDE_CODE_TASK_LIST_ID": "orcas"
  },
  "permissions": {
    "allow": [
      "Bash(chalk ready:*)",
      "Bash(chalk list:*)",
      "Bash(chalk create:*)",
      "Bash(chalk update:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
