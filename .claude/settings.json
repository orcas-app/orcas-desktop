{
  "env": {
    "CLAUDE_CODE_TASK_LIST_ID": "orcas"
  },
  "permissions": {
    "allow": [
      "Bash(tsk list:*)",
      "Bash(tsk create:*)",
      "Bash(tsk update:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
